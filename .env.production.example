# ============================================================
# T6 Platform - Production Environment Variables
# Copy this to .env.production on your Vultr VPS and fill in values
# NEVER commit .env.production to git!
# ============================================================

# --- AI API Keys ---
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Database ---
# Option A: Use Supabase (recommended - managed PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Option B: Use local PostgreSQL on VPS (uncomment and fill)
# DATABASE_URL=postgresql://tsea_user:STRONG_PASSWORD_HERE@localhost:5432/tsea_x

# --- App Config ---
ENVIRONMENT=production
DEBUG=false

# --- Frontend Public Variables ---
# Replace with your actual Vultr VPS IP or domain
NEXT_PUBLIC_BACKEND_URL=https://t6.tsea.asia
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
