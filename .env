# VOKASI2 Environment Variables
# Local Staging Configuration

# ======================
# Core
# ======================
NODE_ENV=production
APP_URL=http://localhost:3000

# ======================
# Database (PostgreSQL 16 + pgvector)
# ======================
DATABASE_URL=postgresql://vokasi:vokasi2secret@localhost:5432/vokasi2
DB_USER=vokasi
DB_PASSWORD=vokasi2secret

# ======================
# Redis
# ======================
REDIS_URL=redis://localhost:6379

# ======================
# Authentication
# ======================
JWT_SECRET=vokasi2-local-staging-secret-12345
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ======================
# OpenRouter (AI Features)
# ======================
OPENROUTER_API_KEY=sk-or-v1-dummy-key-for-local-staging
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=VOKASI2

# Model used for grading/challenge evaluation tasks
EVALUATION_MODEL=anthropic/claude-sonnet-4-7
# Model used for SocraticChat tutor interactions
TUTOR_MODEL=anthropic/claude-sonnet-4-7

# ======================
# Email (Resend)
# ======================
RESEND_API_KEY=re_dummy_key_for_local_staging
EMAIL_FROM=VOKASI2 <noreply@localhost>

# ======================
# Storage (S3-compatible) - disabled for local staging
# ======================
S3_BUCKET=vokasi2-local
S3_REGION=ap-southeast-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ======================
# Webhook Secret
# ======================
WEBHOOK_SECRET=whsec_dummy_for_local_staging

# ======================
# Optional: Monitoring
# ======================
SENTRY_DSN=
