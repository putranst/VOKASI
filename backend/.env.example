# Example Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# AI Service API Keys
# ============================================

# OpenAI API Key (for GPT models)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# Google Gemini API Key (primary AI service)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key (optional fallback service)
# Get from: https://openrouter.ai/keys
# IMPORTANT: never commit a real key. If not set, OpenRouter provider will be skipped.
# For production, configure via Admin Settings > AI Providers (encrypted storage).
# OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ============================================
# Database Configuration
# ============================================

# SQLite (default - no configuration needed)
DATABASE_URL=sqlite:///./tsea.db

# PostgreSQL (if using Supabase or external DB)
# DATABASE_URL=postgresql://user:password@host:port/database

# ============================================
# Supabase Configuration (Optional)
# ============================================

# Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# Application Settings
# ============================================

# Environment
ENVIRONMENT=development

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Secret key for JWT tokens (legacy)
SECRET_KEY=your_secret_key_here_change_in_production

# JWT secret key for new JWT auth implementation (python-jose)
# REQUIRED for production/staging. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# For local development, a safe default will be used with a warning.
JWT_SECRET_KEY=your_jwt_secret_key_change_in_production

# ============================================
# Classroom / WebSocket Auth (OpenMAIC)
# ============================================

# Supabase HS256 JWT secret used to verify ?token=... on /ws/classroom/{id}
# Find it at: https://app.supabase.com/project/_/settings/api -> "JWT Secret"
# REQUIRED for production. If unset in local debug mode with CLASSROOM_AUTH_MODE=lenient,
# tokens are decoded without signature verification (not recommended for production).
SUPABASE_JWT_SECRET=

# Classroom auth enforcement mode: "lenient" (local debug only) or "strict" (production default)
# In strict mode, missing/invalid tokens are rejected on both REST and WS.
# Lenient mode (unsigned decode) is only allowed in development/local environments.
CLASSROOM_AUTH_MODE=strict

# ============================================
# Runtime Environment (used by SQLite guard)
# ============================================
# Set to "production" to enforce PostgreSQL-only (SQLite blocked at startup)
ENV=development

# ============================================
# Midtrans Payment Gateway
# ============================================
# Get from: https://dashboard.midtrans.com/settings/config_info
MIDTRANS_MERCHANT_ID=your_merchant_id
MIDTRANS_CLIENT_KEY=your_client_key
MIDTRANS_SERVER_KEY=your_server_key
# "sandbox" for testing, "production" for live payments
MIDTRANS_ENV=sandbox

# IDR conversion rate (1 USD = N IDR)
IDR_RATE=16000

# ============================================
# Email Service
# ============================================
# Provider: "sendgrid", "postmark", or "noop" (disables sending)
EMAIL_PROVIDER=noop
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your_sendgrid_api_key
# FROM address for transactional emails
EMAIL_FROM=noreply@vokasi.id

# ============================================
# Feature Flags (Beta Campaign)
# ============================================
FF_HYBRID_ONBOARDING=true
FF_EMAIL_EVENTS=true
