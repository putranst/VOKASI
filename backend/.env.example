# VOKASI2 — Backend Environment
# Copy to .env.local for development

# Database
DATABASE_URL=postgresql://vokasi:vokasi2_dev_password@localhost:5432/vokasi2
DB_PASSWORD=vokasi2_dev_password

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=vokasi2_dev_jwt_secret_change_in_production_min_32_chars
JWT_EXPIRY=30d

# OpenRouter (required for AI features)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# Kimi K2.6 (optional, for SocraticChat streaming)
KIMI_API_KEY=...
KIMI_API_BASE=https://api.moonshot.cn/v1

# Sandbox
SANDBOX_DOCKER_IMAGE=vokasi2/sandbox:latest
SANDBOX_TIMEOUT_SECONDS=7200

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development
PORT=3000
