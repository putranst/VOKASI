# Production Environment Variables for Backend
# Copy to .env and fill in real values

ENVIRONMENT=production

# AI API Keys (copy from your dev .env)
GEMINI_API_KEY=your_gemini_key
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Database (SQLite for simplicity — file stored in container volume)
DATABASE_URL=sqlite:///./tsea.db

# Supabase (if using Supabase instead of SQLite)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# CORS (add your AWS IP/domain)
CORS_ORIGINS=http://YOUR-AWS-PUBLIC-IP:3000,http://localhost:3000

# Secret key
SECRET_KEY=change-this-to-a-long-random-string
