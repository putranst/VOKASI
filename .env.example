# VOKASI2 Environment Variables
# Copy to .env and fill in values

# ======================
# Core
# ======================
NODE_ENV=production
APP_URL=https://vokasi2.example.com

# ======================
# Database (PostgreSQL 16 + pgvector)
# ======================
DATABASE_URL=postgresql://vokasi:PASSWORD@localhost:5432/vokasi2
DB_USER=vokasi
DB_PASSWORD=CHANGE_ME_strong_password_here

# ======================
# Redis
# ======================
REDIS_URL=redis://localhost:6379

# ======================
# Authentication
# ======================
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ======================
# OpenRouter (AI)
# ======================
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_SITE_URL=https://vokasi2.example.com
OPENROUTER_SITE_NAME=VOKASI2

# ======================
# Email (Resend)
# ======================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=VOKASI2 <noreply@vokasi2.example.com>

# ======================
# Storage (S3-compatible)
# ======================
S3_BUCKET=vokasi2-uploads
S3_REGION=ap-southeast-1
S3_ENDPOINT=https://s3.ap-southeast-1.amazonaws.com
S3_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ======================
# Webhook Secret
# ======================
WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ======================
# Optional: Monitoring
# ======================
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
