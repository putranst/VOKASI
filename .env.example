# VOKASI Platform — Environment Variables Example
# Copy to .env and fill in real values before deploying.
# Never commit the real .env file.

# ── Domain ───────────────────────────────────────────────────────────────────
# Your public domain (Caddy provisions HTTPS automatically)
VOKASI_DOMAIN=vokasi.example.com

# ── Frontend (baked at build time — must match your domain) ──────────────────
NEXT_PUBLIC_BACKEND_URL=https://vokasi.example.com
NEXT_PUBLIC_API_URL=https://vokasi.example.com
NEXT_PUBLIC_ENVIRONMENT=production

# Supabase (optional — for legacy auth; leave blank if using JWT-only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Backend ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://vokasi_user:CHANGE_ME@db:5432/vokasi

# JWT secret (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_32_CHAR_HEX

# Admin config encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ADMIN_CONFIG_ENCRYPTION_KEY=

# ── AI Provider ───────────────────────────────────────────────────────────────
# OpenRouter API key (https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-...

# Gemini API key (optional fallback)
GEMINI_API_KEY=

# ── Institution Branding ──────────────────────────────────────────────────────
# Default institution ID for ThemeInjector (usually 1)
NEXT_PUBLIC_DEFAULT_INSTITUTION_ID=1

# ── Beta Scholarship Campaign (Phase 5.1) ───────────────────────────────────
# Midtrans backend credentials
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_ENV=sandbox

# Midtrans public keys for frontend build
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
NEXT_PUBLIC_MIDTRANS_ENV=sandbox

# Pricing conversion (USD -> IDR), used by cohort pricing endpoint
IDR_RATE=16000

# Public frontend URL for Midtrans callback redirect
FRONTEND_URL=https://vokasi.example.com
